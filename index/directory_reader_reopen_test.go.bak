// Package index_test contains tests for the index package.
//
// Ported from Apache Lucene's org.apache.lucene.idx.TestDirectoryReaderReopen
// GC-186: Test DirectoryReader Reopen
//
// Test Coverage:
//   - Reopen after document additions/deletions
//   - Concurrent modifications
//   - NRT (Near Real Time) reader behavior
//   - Commit-based reopen
//   - Thread safety
package index_test

import (
	"fmt"
	"math/rand"
	"sync"
	"testing"
	"time"

	"github.com/FlavioCFOliveira/Gocene/analysis"
